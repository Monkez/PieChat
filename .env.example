# =============================================================================
# PieChat Production Environment
# =============================================================================
# Copy this file to .env and update the values before deploying
# =============================================================================

# ─── Domain Configuration ───────────────────────────────────────────────────
# Your domain name (e.g., chat.example.com)
DOMAIN=chat.example.com

# Matrix server name — used for user IDs (@user:server_name)
# Usually same as DOMAIN, set this ONCE and never change
MATRIX_SERVER_NAME=chat.example.com

# Email for Let's Encrypt SSL certificate
SSL_EMAIL=your-email@example.com

# ─── Security ───────────────────────────────────────────────────────────────
# Dendrite registration shared secret (change this!)
REGISTRATION_SHARED_SECRET=change_me_to_a_random_string_2026

# CORS origins allowed to connect
CORS_ORIGINS=https://chat.example.com

# ─── Auth Service ───────────────────────────────────────────────────────────
# Dev password for testing (remove in real production)
DEV_MATRIX_PASSWORD=Pass@12345

# SMS Provider (uncomment when ready)
# SMS_PROVIDER=webhook
# SMS_BRANDNAME=PieChat
# SMS_WEBHOOK_URL=https://your-sms-gateway.com/api/send
