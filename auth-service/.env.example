# PieChat Auth Service Environment
# Copy this to .env and adjust values

# Port for the auth service
PORT=4000

# Matrix homeserver base URL
MATRIX_BASE_URL=http://localhost:8008

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,tauri://localhost,capacitor://localhost

# Redis URL (optional — in-memory fallback when not set)
# REDIS_URL=redis://localhost:6379

# SMS Provider Configuration
# SMS_PROVIDER=webhook
# SMS_BRANDNAME=PieChat
# SMS_TEMPLATE={{otp}} la ma OTP dang nhap PieChat, hieu luc 5 phut.
# SMS_WEBHOOK_URL=https://your-sms-gateway.com/api/send

# Phone number to Matrix username mapping (JSON)
# PHONE_AUTH_MAP={}

# Dev mode: allow dev passwords (set NODE_ENV=development)
# DEV_MATRIX_PASSWORD=Pass@12345
